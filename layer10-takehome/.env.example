# === Database ===
DATABASE_URL=postgresql+asyncpg://layer10:layer10pass@localhost:5432/layer10
DATABASE_URL_SYNC=postgresql://layer10:layer10pass@localhost:5432/layer10

POSTGRES_USER=layer10
POSTGRES_PASSWORD=layer10pass
POSTGRES_DB=layer10
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === LLM Providers ===
# Primary: Groq (Llama 3.3 70B) — 14,400 req/day, 6,000 tokens/min
GROQ_API_KEY=gsk_REPLACE_ME
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Fallback: Google AI Studio (Gemini 2.5 Flash)
GOOGLE_API_KEY=REPLACE_ME
GOOGLE_MODEL=gemini-2.5-flash

# === Extraction Settings ===
EXTRACTION_BATCH_SIZE=10
EXTRACTION_MAX_RETRIES=3
EXTRACTION_MIN_CONFIDENCE=0.4
EXTRACTION_RATE_LIMIT_RPM=80

# === Embedding Model ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# === Enron Dataset ===
ENRON_DATA_DIR=./data/enron_raw/maildir
ENRON_SUBSET_USERS=allen-p,bass-e,beck-s,campbell-l,dasovich-j,farmer-d,germany-c,kaminski-v,lay-k,skilling-j

# === API ===
API_HOST=0.0.0.0
API_PORT=8000

# === Logging ===
LOG_LEVEL=INFO
